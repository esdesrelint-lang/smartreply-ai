<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
           xsi:type="MailApp">

  <Id>b07bf011-50e0-4561-8ae6-40dffb64f97e</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>SmartReply AI</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="SmartReply AI"/>
  <Description DefaultValue="AI-powered email reply assistant with learning capabilities"/>
  <IconUrl DefaultValue="https://esdesrelint-lang.github.io/smartreply-ai/taskpane.html"/>
  <HighResolutionIconUrl DefaultValue="https://esdesrelint-lang.github.io/smartreply-ai/taskpane.html"/>
  <SupportUrl DefaultValue="https://esdesrelint-lang.github.io/smartreply-ai/taskpane.html"/>
  <AppDomains>
    <AppDomain>https://esdesrelint-lang.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://esdesrelint-lang.github.io/smartreply-ai/taskpane.html"/>
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteMailbox</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>
  <DisableEntityHighlighting>false</DisableEntityHighlighting>

</OfficeApp>
